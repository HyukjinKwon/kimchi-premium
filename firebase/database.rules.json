{
  "rules": {
    "messages": {
      ".read": true,
      ".indexOn": ["ts"],
      "$messageId": {
        ".write": "newData.exists() || data.exists()",
        ".validate": "newData.hasChildren(['from', 'text', 'ts'])",
        "from":        { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 50" },
        "emoji":       { ".validate": "newData.isString() && newData.val().length <= 10" },
        "text":        { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 500" },
        "ts":          { ".validate": "newData.val() == now || data.child('ts').exists()" },
        "isPrediction":{ ".validate": "newData.isBoolean()" },
        "textBold":    { ".validate": "newData.isString() && newData.val().length <= 200" },
        "deleted":     { ".validate": "newData.isBoolean()" },
        "deletedBy":   { ".validate": "newData.isString() && newData.val().length <= 50" },
        "$other":      { ".validate": false }
      }
    },
    "presence": {
      ".read": true,
      "$sessionId": {
        ".write": true,
        ".validate": "newData.hasChildren(['name', 'ts'])",
        "name":  { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20" },
        "emoji": { ".validate": "newData.isString() && newData.val().length <= 10" },
        "uid":   { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 50" },
        "ts":    { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },
    "scores": {
      ".read": true,
      "$sessionId": {
        ".write": true,
        ".validate": "newData.hasChildren(['points', 'tries'])",
        "correct": { ".validate": "newData.isNumber()" },
        "tries":   { ".validate": "newData.isNumber()" },
        "points":  { ".validate": "newData.isNumber()" },
        "ts":      { ".validate": "newData.isNumber()" },
        "$other":  { ".validate": false }
      }
    },
    "predictions": {
      ".read": true,
      "$userId": {
        ".write": "(!data.exists() && newData.exists() && newData.child('targetTs').val() > now && newData.child('targetTs').val() <= now + 660000 && newData.child('bet').val() > 0 && (!root.child('scores').child($userId).child('points').exists() || newData.child('bet').val() <= root.child('scores').child($userId).child('points').val())) || (data.exists() && !newData.exists())",
        ".validate": "!newData.exists() || newData.hasChildren(['symbol', 'targetPrice', 'targetTs', 'bet'])",
        "symbol":      { ".validate": "newData.isString() && (newData.val() == 'BTC' || newData.val() == 'ETH' || newData.val() == 'XRP' || newData.val() == 'SOL')" },
        "targetPrice": { ".validate": "newData.isNumber() && newData.val() > 0" },
        "targetTs":    { ".validate": "newData.isNumber()" },
        "bet":         { ".validate": "newData.isNumber() && newData.val() > 0" },
        "$other":      { ".validate": false }
      }
    },
    "visitors": {
      ".read": true,
      ".indexOn": ["ts"],
      "$userId": {
        ".write": true,
        ".validate": "newData.hasChildren(['ts'])",
        "ts": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },
    "settings": {
      ".read": true,
      "pointsReset": {
        ".write": true,
        ".validate": "newData.hasChildren(['ts', 'points'])",
        "ts":     { ".validate": "newData.isNumber()" },
        "points": { ".validate": "newData.isNumber() && newData.val() > 0" },
        "$other": { ".validate": false }
      }
    },
    "$other": { ".read": false, ".write": false }
  }
}
